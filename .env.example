# Copy this file to .env.local and fill in your Supabase project values.
# Find these in your Supabase project: Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: enables the in-app AI assistant widget (RAG over your DB).
# Create a free key at https://console.groq.com/keys — server-only, do NOT prefix with NEXT_PUBLIC_.
GROQ_API_KEY=
